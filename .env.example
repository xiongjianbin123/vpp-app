# ─── PostgreSQL ──────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/vpp_db
# Or use individual fields:
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=vpp_db
# DB_USER=postgres
# DB_PASSWORD=password

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-string-in-production
JWT_EXPIRES_IN=7d

# ─── Session (for OAuth state) ────────────────────────────────────────────────
SESSION_SECRET=another-long-random-string

# ─── GitHub OAuth ─────────────────────────────────────────────────────────────
# Create an OAuth App at https://github.com/settings/developers
# Homepage URL: http://localhost:5176
# Authorization callback URL: http://localhost:3002/api/auth/github/callback
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_CALLBACK_URL=http://localhost:3002/api/auth/github/callback

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=3002
FRONTEND_URL=http://localhost:5176
NODE_ENV=development

# ─── AI / LLM ────────────────────────────────────────────────────────────────
AI_PROVIDER=minimax
AI_MODEL=MiniMax-M2
AI_API_KEY=your-api-key-here
AI_BASE_URL=https://api.minimaxi.com/v1
AI_MAX_TOKENS=2048
